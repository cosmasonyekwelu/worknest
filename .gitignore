# Root-level ignore rules for the WorkNest workspace.
# These apply to both the frontend and backend projects.

# Local tooling and workspace state
.worknest-test/

.codex/
.codex-smoke/
.qodo/
**/.qodo/
.claude/
.cursor/

# Dependencies
node_modules/
**/node_modules/
.npm/
.pnpm-store/
.yarn/

# Environment files and secrets
.env
.env.*
**/.env
**/.env.*
.envrc
**/.envrc
.direnv/
**/.direnv/
!.env.example
!**/.env.example
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
*.jks
*.keystore
*.kdbx
*.ovpn
service-account*.json
serviceAccount*.json
credentials*.json
firebase-adminsdk*.json
secrets/
**/secrets/

# Build output
dist/
build/
out/
coverage/
.cache/
.parcel-cache/
.vite/
.next/
.nuxt/
.svelte-kit/
**/dist/
**/build/
**/coverage/

# Runtime and logs
logs/
*.log
*.pid
*.pid.lock
*.seed
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Tests
.nyc_output/
playwright-report/
test-results/

# OS / editor files
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.tmp
*.bak
*~

# Local tooling / caches
.eslintcache
.stylelintcache
.turbo/
.vercel/
.netlify/
.serverless/
.aws-sam/
.terraform/
*.tfstate
*.tfstate.*

# Archives and database files that should not be committed by accident
*.sqlite
*.sqlite3
*.db
*.zip
*.tar
*.gz
*.7z
*.rar

# Temporary directories
tmp/
temp/
.tmp/
