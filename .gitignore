# Root-level ignore rules for the WorkNest workspace.
# These apply to both the frontend and backend projects.

# Dependencies
node_modules/
**/node_modules/
.npm/
.pnpm-store/
.yarn/

# Environment files and secrets
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
secrets/
**/secrets/

# Build output
dist/
build/
out/
coverage/
.cache/
.parcel-cache/
.vite/
.next/
.nuxt/
.svelte-kit/
**/dist/
**/build/
**/coverage/

# Runtime and logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Tests
.nyc_output/
playwright-report/
test-results/

# OS / editor files
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.tmp
*.bak
*~

# Local tooling / caches
.eslintcache
.stylelintcache
.turbo/
.vercel/
.netlify/

# Archives and database files that should not be committed by accident
*.sqlite
*.sqlite3
*.db
*.zip
*.tar
*.gz
