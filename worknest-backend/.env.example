NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://worknest-silk.vercel.app

MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net
DATABASE_NAME=worknest_server

JWT_SECRET_KEY=replace_with_a_strong_secret_min_16_chars
JWT_ACCESS_SECRET_KEY=replace_with_a_different_strong_secret_min_16_chars
JWT_REFRESH_SECRET_KEY=replace_with_a_different_strong_secret_min_16_chars
JWT_ACCESS_TOKEN_EXPIRES=15m
JWT_REFRESH_TOKEN_EXPIRES=7d
MONITORING_TOKEN=replace_with_a_strong_monitoring_token
GOOGLE_CLIENT_ID=your_google_oauth_client_id

BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=Worknest

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

GROQ_API_KEY=your_groq_api_key
AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AI_SHORTLIST_THRESHOLD=50
AI_REQUEST_TIMEOUT_MS=15000

# Optional shared rate-limit store adapter module.
# Export a factory function that receives { scope, windowMs, max } and returns
# an express-rate-limit compatible store instance.
RATE_LIMIT_STORE_MODULE=

# Optional shared cache store adapter module.
# Export a factory function that returns an object with async get/set/del/keys methods.
CACHE_STORE_MODULE=
